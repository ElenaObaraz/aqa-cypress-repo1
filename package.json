{
  "devDependencies": {
    "cypress": "^15.12.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  },
  "scripts": {
    "cy:qauto": "cypress run --config-file cypress.config.qauto.js",
    "cy:qauto2": "cypress run --config-file cypress.config.qauto2.js",
    "cy:run": "cypress run",
    "cy:report:merge": "npx mochawesome-merge cypress/reports/mochawesome/*.json > cypress/reports/mochawesome/mochawesome.json",
    "cy:report:html": "npx marge cypress/reports/mochawesome/mochawesome.json -f index -o cypress/reports/mochawesome",
    "cy:report": "npm run cy:report:merge && npm run cy:report:html",
    "cy:qauto:garage": "cypress run --config-file cypress.config.qauto.js --spec cypress/e2e/21-Cypress-reporters/tests/garage.cy.js",
    "cy:qauto2:garage": "cypress run --config-file cypress.config.qauto2.js --spec cypress/e2e/21-Cypress-reporters/tests/garage.cy.js",
    "cy:qauto:expenses": "cypress run --config-file cypress.config.qauto.js --spec cypress/e2e/21-Cypress-reporters/tests/fuelExpenses.cy.js",
    "cy:qauto2:expenses": "cypress run --config-file cypress.config.qauto2.js --spec cypress/e2e/21-Cypress-reporters/tests/fuelExpenses.cy.js",
    "open:qauto": "cypress open --config-file cypress.config.qauto.js",
    "open:qauto2": "cypress open --config-file cypress.config.qauto2.js"
  }
}
